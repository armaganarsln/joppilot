rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default Deny Catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Path Variable & ID Hardening. The character allow-list regex already
    // rejects anything unsafe, so no separate blacklist check is needed.
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    // Admin allowlist — the single enforcement point for elevated privileges.
    // Keep in sync with src/config/access.ts (client UX only; this is authoritative).
    function isAdminEmail() {
      return request.auth != null
        && request.auth.token.email != null
        && (
          request.auth.token.email.lower() == 'armagan@joeppli.ch' ||
          request.auth.token.email.lower() == 'armaganarsln@gmail.com' ||
          request.auth.token.email.lower() == 'afra@joeppli.ch'
        );
    }

    // Schema Validation for TestVehicle
    function isValidTestVehicle(data) {
      return data.id is string
        && data.id.size() <= 128
        && data.name is string
        && data.name.size() <= 64
        && data.isActive is bool
        && data.avState is string
        && data.lat is number
        && data.lng is number
        && data.speed is number
        && data.heading is number
        && data.battery is number
        && data.updatedAt is number;
    }

    // Schema Validation for WebRTCSignaling
    function isValidWebRTCSignaling(data) {
      return data.id is string
        && data.id.size() <= 128
        && data.updatedAt is number;
    }

    match /test_vehicles/{vehicleId} {
      allow get, list: if true;
      allow create, update: if isValidId(vehicleId) 
        && isValidTestVehicle(incoming());
      allow delete: if isValidId(vehicleId);
    }

    match /webrtc_signaling/{vehicleId} {
      allow get, list: if true;
      allow create, update: if isValidId(vehicleId)
        && isValidWebRTCSignaling(incoming());
      allow delete: if isValidId(vehicleId);
    }

    // Teleoperation control lock (single-operator-per-vehicle, RD-7). Open for
    // the testbed, consistent with the other teleop collections; tighten
    // alongside test_vehicles/webrtc_signaling when those move behind auth.
    match /control_locks/{vehicleId} {
      allow read, write: if isValidId(vehicleId);
    }

    // Operator Profile Collection.
    // role/status are authorization-bearing fields. A regular user may only ever
    // create/keep themselves as a pending 'operator'; elevation to admin or to
    // an approved/rejected status is restricted to the admin allowlist. This
    // prevents a signed-in user from self-promoting to admin via the client SDK.
    match /operators/{operatorId} {
      // Users can read their own profile; admins can read any single profile.
      allow get: if request.auth != null && (request.auth.uid == operatorId || isAdminEmail());
      // Only admins may query/list the collection (e.g. the approval queue).
      allow list: if isAdminEmail();

      allow create: if request.auth != null && request.auth.uid == operatorId && (
        isAdminEmail() ||
        (incoming().role == 'operator' && incoming().status == 'pending')
      );

      allow update: if request.auth != null && (
        isAdminEmail() ||
        (
          request.auth.uid == operatorId &&
          incoming().role == 'operator' &&
          incoming().status != 'approved' &&
          incoming().status != 'rejected'
        )
      );

      allow delete: if isAdminEmail();
    }

    // Mail Queue Collection (Firestore "Trigger Email" extension).
    // Any signed-in user may enqueue their own approval-request email; only
    // admins can read or manage the queue.
    match /mail/{mailId} {
      allow create: if request.auth != null;
      allow read, update, delete: if isAdminEmail();
    }
  }
}
